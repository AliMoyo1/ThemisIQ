<div class="page-head">
  <div>
    <h1><%= mod ? 'Edit training module' : 'New training module' %></h1>
    <p>Build an in-house micro-course your team can complete and sign off on.</p>
  </div>
</div>

<form method="POST" action="<%= mod ? '/training/' + mod.id : '/training' %>" class="card stack-16">
  <div class="form-row cols-2">
    <div><label>Title *</label><input name="title" required value="<%= mod?.title || '' %>"/></div>
    <div><label>Category</label>
      <select name="category">
        <% const cats = ['','BCM fundamentals','Incident response','Crisis communications','Cyber resilience','Compliance','Leadership','Technical','Other']; %>
        <% cats.forEach(c => { %>
          <option value="<%= c %>" <%= mod?.category === c ? 'selected' : '' %>><%= c || 'Select…' %></option>
        <% }) %>
      </select>
    </div>
  </div>

  <div><label>Description</label><textarea name="description" rows="2"><%= mod?.description || '' %></textarea></div>

  <div class="form-row cols-3">
    <div><label>Duration (min)</label><input type="number" min="1" name="duration_minutes" value="<%= mod?.duration_minutes || 15 %>"/></div>
    <div><label>Renewal (months, 0 = one-time)</label><input type="number" min="0" name="renewal_months" value="<%= mod?.renewal_months ?? 12 %>"/></div>
    <div><label>Passing score</label><input type="number" min="0" max="100" name="passing_score" value="<%= mod?.passing_score ?? 80 %>"/></div>
  </div>

  <div class="form-row cols-2">
    <div><label>Required roles (comma-separated, blank = all)</label>
      <input name="required_roles" placeholder="admin,manager,responder" value="<%= mod?.required_roles || '' %>"/>
    </div>
    <div><label>Owner</label><input name="owner" value="<%= mod?.owner || user.name %>"/></div>
  </div>

  <div><label>Content (Markdown) — this is what learners will read</label>
    <textarea name="content" rows="16" placeholder="# Module content&#10;&#10;## Learning objectives&#10;- …&#10;&#10;## Procedures&#10;1. …"><%= mod?.content || '' %></textarea>
  </div>

  <div><label>Status</label>
    <select name="status">
      <% ['active','draft','archived'].forEach(s => { %>
        <option value="<%= s %>" <%= (mod?.status || 'active') === s ? 'selected' : '' %>><%= s %></option>
      <% }) %>
    </select>
  </div>

  <div style="display:flex; gap:10px;">
    <button class="btn primary" type="submit"><%= mod ? 'Save changes' : 'Create module' %></button>
    <a class="btn ghost" href="/training">Cancel</a>
  </div>
</form>
