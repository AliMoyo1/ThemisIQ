<div class="page-head">
  <div>
    <a href="/training" class="muted">&larr; Training</a>
    <h1>Attestation log</h1>
    <p>All signed attestations across the workspace. Use this for compliance audits.</p>
  </div>
</div>

<div class="card">
  <% if (rows.length === 0) { %>
    <p class="muted" style="padding:20px 0;">No attestations yet.</p>
  <% } else { %>
    <table class="table">
      <thead><tr><th>Signed at</th><th>User</th><th>Module</th><th>Score</th><th>Expires</th><th>IP</th></tr></thead>
      <tbody>
        <% rows.forEach(r => { %>
          <tr>
            <td><%= r.attested_at %></td>
            <td><%= r.user_name || r.user_email %></td>
            <td><a href="/training/<%= r.module_id %>"><%= r.module_title || '(removed module)' %></a></td>
            <td><%= r.score ?? '—' %></td>
            <td><%= r.expires_at || '—' %></td>
            <td class="muted" style="font-size:12px;"><%= r.ip || '—' %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>
