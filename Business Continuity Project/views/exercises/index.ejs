<div class="page-head">
  <div>
    <h1>Exercises</h1>
    <p>Tabletops, walkthroughs, and simulations — with after-action reports.</p>
  </div>
  <div class="actions"><a class="btn primary" href="/exercises/new">+ Schedule exercise</a></div>
</div>

<div class="grid grid-4" style="margin-bottom:16px;">
  <div class="card kpi"><div class="kpi-label">Total</div><div class="kpi-value"><%= stats.total %></div></div>
  <div class="card kpi"><div class="kpi-label">Planned</div><div class="kpi-value"><%= stats.planned %></div></div>
  <div class="card kpi"><div class="kpi-label">Completed</div><div class="kpi-value"><%= stats.completed %></div></div>
  <div class="card kpi"><div class="kpi-label">Pass rate</div><div class="kpi-value"><%= stats.completed ? Math.round(stats.passed / stats.completed * 100) + '%' : '—' %></div></div>
</div>

<div class="card">
  <% if (rows.length === 0) { %>
    <p class="muted" style="padding:20px 0;">No exercises scheduled yet. A tabletop keeps plans fresh and builds responder muscle memory.</p>
  <% } else { %>
    <table class="table">
      <thead>
        <tr><th>Title</th><th>Type</th><th>Plan</th><th>Scheduled</th><th>Facilitator</th><th>Status</th><th>Outcome</th><th></th></tr>
      </thead>
      <tbody>
        <% rows.forEach(e => {
           const statusCls = e.status === 'completed' ? 'success' : (e.status === 'in_progress' ? 'warn' : (e.status === 'cancelled' ? 'muted' : 'info'));
           const outCls = e.outcome === 'pass' ? 'success' : (e.outcome === 'partial' ? 'warn' : (e.outcome === 'fail' ? 'danger' : 'muted'));
        %>
          <tr>
            <td><strong><%= e.title %></strong></td>
            <td><%= e.type %></td>
            <td><%= e.plan_title || '—' %></td>
            <td><%= e.scheduled_date || '—' %></td>
            <td><%= e.facilitator || '—' %></td>
            <td><span class="badge <%= statusCls %>"><%= e.status %></span></td>
            <td><% if (e.outcome) { %><span class="badge <%= outCls %>"><%= e.outcome %></span><% } else { %>—<% } %></td>
            <td class="right"><a href="/exercises/<%= e.id %>">Open</a></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>
