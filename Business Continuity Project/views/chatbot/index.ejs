<div class="page-head">
  <div>
    <h1>BCM Chatbot</h1>
    <p>Ask about ISO 22301, playbooks, or "what should we do if...". Responses are scoped to your workspace.</p>
  </div>
  <div class="actions">
    <form method="POST" action="/chatbot/clear" data-confirm="Clear conversation history?" style="display:inline;">
      <button class="btn" type="submit">Clear chat</button>
    </form>
  </div>
</div>

<div class="chat-wrap">
  <div class="chat-stream" id="stream">
    <% if (messages.length === 0) { %>
      <div class="chat-msg assistant">
        <div class="avatar-sm">AI</div>
        <div class="bubble">
Hi, I'm your Continuity Copilot. Ask me things like:

• "What should we do if our primary data center goes offline?"
• "Draft a tabletop exercise for a ransomware scenario."
• "What are the ISO 22301 requirements for a BIA?"
• "Our top supplier just declared bankruptcy — walk me through next steps."
        </div>
      </div>
    <% } %>
    <% messages.forEach(m => { %>
      <div class="chat-msg <%= m.role === 'user' ? 'user' : 'assistant' %>">
        <% if (m.role !== 'user') { %><div class="avatar-sm">AI</div><% } %>
        <div class="bubble"><%= m.content %></div>
        <% if (m.role === 'user') { %><div class="avatar-sm" style="background:#0f1116; color:#fff;"><%= (user.name || 'U').split(' ').map(n=>n[0]).slice(0,2).join('').toUpperCase() %></div><% } %>
      </div>
    <% }) %>
  </div>

  <form method="POST" action="/chatbot" class="chat-form" id="chatForm">
    <textarea name="message" id="chatInput" placeholder="Ask the copilot... (Shift+Enter for a newline)" required></textarea>
    <button class="btn primary" type="submit">Send</button>
  </form>
</div>

<script>
(function() {
  const stream = document.getElementById('stream');
  if (stream) stream.scrollTop = stream.scrollHeight;
  const input = document.getElementById('chatInput');
  const form = document.getElementById('chatForm');
  if (input && form) {
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        form.submit();
      }
    });
  }
})();
</script>
