<div class="page-head">
  <div>
    <h1><%= plan ? 'Edit plan' : 'New continuity plan' %></h1>
    <p>Document the response, recovery, and communications approach.</p>
  </div>
  <div class="actions"><a class="btn" href="/bcp">Back</a></div>
</div>

<div class="card">
  <form method="POST" action="<%= plan ? '/bcp/' + plan.id : '/bcp' %>" class="stack-16">
    <div><label>Title</label><input name="title" required value="<%= plan ? plan.title : '' %>" /></div>
    <div class="form-row cols-2">
      <div><label>Scope</label><input name="scope" value="<%= plan ? plan.scope || '' : '' %>" placeholder="e.g. Payments platform, London office" /></div>
      <div><label>Owner</label><input name="owner" value="<%= plan ? plan.owner || '' : '' %>" /></div>
    </div>
    <div class="form-row cols-3">
      <div><label>Version</label><input name="version" value="<%= plan ? plan.version : '1.0' %>" /></div>
      <div><label>Status</label>
        <select name="status">
          <% ['draft','approved','archived'].forEach(s => { %>
            <option value="<%= s %>" <%= plan && plan.status === s ? 'selected' : '' %>><%= s %></option>
          <% }) %>
        </select>
      </div>
      <div><label>Last reviewed</label><input type="date" name="last_reviewed" value="<%= plan ? plan.last_reviewed || '' : '' %>" /></div>
    </div>
    <div><label>Next review</label><input type="date" name="next_review" value="<%= plan ? plan.next_review || '' : '' %>" /></div>
    <div>
      <label>Plan content (Markdown supported)</label>
      <textarea name="content" style="min-height:320px; font-family: ui-monospace, SFMono-Regular, Menlo, monospace;"><%= plan ? plan.content || '' : '## Purpose\n\n## Scope\n\n## Activation Criteria\n\n## Roles & Responsibilities\n\n## Response Procedures\n\n## Recovery Steps\n\n## Communications\n\n## Dependencies\n\n## Review & Approval' %></textarea>
    </div>

    <div style="border-top:1px solid var(--border); padding-top:16px; margin-top:4px;">
      <label style="display:block; margin-bottom:4px;">Business processes this plan recovers</label>
      <p class="muted" style="font-size:12.5px; margin:0 0 10px 0;">
        Tick the BIA records whose processes are recovered by this plan. Use <strong>primary</strong> for processes this plan is the authoritative runbook for — those will be marked "covered" in the coverage map.
      </p>
      <% if (!bias || !bias.length) { %>
        <p class="muted" style="font-size:13px;">No BIA records exist yet. <a href="/bia/new">Add a process</a> and come back to link it.</p>
      <% } else {
           const linkedMap = {};
           (links || []).forEach(l => { linkedMap[l.bia_id] = l.coverage_type || 'primary'; });
      %>
        <div style="display:flex; flex-direction:column; gap:6px; max-height:320px; overflow:auto; border:1px solid var(--border); border-radius:8px; padding:8px;">
          <% bias.forEach(b => {
               const checked = linkedMap.hasOwnProperty(b.id);
               const current = linkedMap[b.id] || 'primary';
               const crit = b.criticality || '—';
               const ccls = crit === 'Critical' ? 'danger' : (crit === 'High' ? 'warn' : (crit === 'Medium' ? 'info' : 'muted'));
          %>
            <div style="display:grid; grid-template-columns:22px 1fr 90px 160px; align-items:center; gap:10px; padding:6px 4px;">
              <input type="checkbox" name="bia_ids" value="<%= b.id %>" <%= checked ? 'checked' : '' %> />
              <div style="font-size:13.5px;">
                <strong><%= b.process_name %></strong>
                <span class="muted" style="font-size:12px;">
                  <% if (b.department) { %> · <%= b.department %><% } %>
                  <% if (b.rto_hours != null) { %> · RTO <%= b.rto_hours %>h<% } %>
                </span>
              </div>
              <span class="badge <%= ccls %>" style="justify-self:start;"><%= crit %></span>
              <select name="coverage_for_bia_<%= b.id %>" style="font-size:12.5px; padding:4px 6px;">
                <% ['primary','secondary','partial','referenced'].forEach(t => { %>
                  <option value="<%= t %>" <%= current === t ? 'selected' : '' %>><%= t %></option>
                <% }) %>
              </select>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <div class="flex gap-8">
      <button class="btn primary" type="submit"><%= plan ? 'Save changes' : 'Create plan' %></button>
      <a class="btn" href="/bcp">Cancel</a>
    </div>
  </form>
</div>
