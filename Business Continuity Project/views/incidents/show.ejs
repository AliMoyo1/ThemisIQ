<div class="page-head">
  <div>
    <h1><%= incident.title %></h1>
    <p>Commander: <%= incident.commander || '—' %> · Started: <%= incident.started_at %></p>
  </div>
  <div class="actions">
    <a class="btn primary" href="/incidents/<%= incident.id %>/command">Open command console</a>
    <a class="btn" href="/incidents">Back</a>
    <a class="btn" href="/incidents/<%= incident.id %>/edit">Edit</a>
    <form method="POST" action="/incidents/<%= incident.id %>/delete" data-confirm="Delete this incident?" style="display:inline;">
      <button class="btn danger" type="submit">Delete</button>
    </form>
  </div>
</div>

<div class="grid grid-3" style="margin-bottom:16px;">
  <div class="kpi"><div class="k-label">Severity</div><div class="k-value"><span class="badge severity-<%= incident.severity %>" style="font-size:14px; padding:6px 14px;"><%= incident.severity %></span></div></div>
  <div class="kpi"><div class="k-label">Status</div><div class="k-value"><%= incident.status %></div></div>
  <div class="kpi"><div class="k-label">Resolved</div><div class="k-value"><%= incident.resolved_at || '—' %></div></div>
</div>

<div class="grid grid-2">
  <div class="card">
    <div class="card-head"><div class="card-title">Overview</div></div>
    <p><strong>Affected:</strong> <%= incident.affected_systems || '—' %></p>
    <p><%= incident.description || 'No description.' %></p>
  </div>
  <div class="card">
    <div class="card-head"><div class="card-title">Response timeline</div></div>
    <form method="POST" action="/incidents/<%= incident.id %>/updates" class="stack-10" style="margin-bottom:14px;">
      <textarea name="note" placeholder="Post an update..." required></textarea>
      <button class="btn primary small" type="submit">Post update</button>
    </form>
    <% if (updates.length === 0) { %>
      <p class="muted">No updates yet. Post the first one above.</p>
    <% } %>
    <% updates.forEach(u => { %>
      <div class="list-row">
        <div class="avatar"><%= (u.author || 'S').split(' ').map(n=>n[0]).slice(0,2).join('').toUpperCase() %></div>
        <div class="body">
          <div class="title"><%= u.note %></div>
          <div class="sub"><%= u.author || 'System' %> · <%= u.created_at %></div>
        </div>
      </div>
    <% }) %>
  </div>
</div>
