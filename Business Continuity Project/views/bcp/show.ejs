<div class="page-head">
  <div>
    <h1><%= plan.title %></h1>
    <p>v<%= plan.version %> · <%= plan.scope || 'No scope' %> · Owner: <%= plan.owner || '—' %></p>
  </div>
  <div class="actions">
    <a class="btn" href="/bcp">Back</a>
    <a class="btn" href="/bcp/<%= plan.id %>/edit">Edit</a>
    <a class="btn" href="/bcp/<%= plan.id %>/review">Review with AI</a>
    <a class="btn primary" href="/bcp/<%= plan.id %>/export.docx">Export to Word</a>
    <form method="POST" action="/bcp/<%= plan.id %>/delete" data-confirm="Delete this plan?" style="display:inline;">
      <button class="btn danger" type="submit">Delete</button>
    </form>
  </div>
</div>

<div class="grid grid-3" style="margin-bottom:16px;">
  <div class="kpi"><div class="k-label">Status</div><div class="k-value"><%= plan.status %></div></div>
  <div class="kpi"><div class="k-label">Last reviewed</div><div class="k-value"><%= plan.last_reviewed || '—' %></div></div>
  <div class="kpi"><div class="k-label">Next review</div><div class="k-value"><%= plan.next_review || '—' %></div></div>
</div>

<%
  const covered = linkedBias || [];
  const primaryCount = covered.filter(b => b.coverage_type === 'primary').length;
  let covLabel, covCls;
  if (!covered.length) { covLabel = 'Orphan plan — no processes linked'; covCls = 'danger'; }
  else if (primaryCount) { covLabel = `Primary for ${primaryCount} process${primaryCount === 1 ? '' : 'es'}`; covCls = 'success'; }
  else { covLabel = `Supports ${covered.length} process${covered.length === 1 ? '' : 'es'}`; covCls = 'warn'; }

  // Tightest RTO across linked processes — the aggressive recovery target this
  // plan must meet to satisfy its processes.
  const rtos = covered.map(b => b.rto_hours).filter(v => v != null);
  const tightestRto = rtos.length ? Math.min(...rtos) : null;
%>
<div class="card" style="margin-bottom:16px;">
  <div class="card-head" style="display:flex; justify-content:space-between; align-items:center;">
    <div class="card-title">Processes covered</div>
    <div style="display:flex; gap:8px; align-items:center;">
      <span class="badge <%= covCls %>"><%= covLabel %></span>
      <% if (tightestRto != null) { %><span class="badge info">Tightest RTO: <%= tightestRto %>h</span><% } %>
      <a class="btn" style="padding:4px 10px; font-size:12.5px;" href="/bcp/<%= plan.id %>/edit#bias">Manage</a>
    </div>
  </div>
  <% if (!covered.length) { %>
    <p class="muted">This plan isn't linked to any BIA process. Without a linked process, the plan is orphaned — no one knows when to activate it.
      <a href="/bcp/<%= plan.id %>/edit">Link a process →</a></p>
  <% } else { %>
    <table class="table">
      <thead>
        <tr><th>Process</th><th>Department</th><th>Criticality</th><th>RTO</th><th>RPO</th><th>Coverage</th><th></th></tr>
      </thead>
      <tbody>
        <% covered.forEach(b => {
             const crit = b.criticality || '—';
             const critCls = crit === 'Critical' ? 'danger' : (crit === 'High' ? 'warn' : (crit === 'Medium' ? 'info' : 'muted'));
             const ccls = b.coverage_type === 'primary' ? 'success'
                         : b.coverage_type === 'secondary' ? 'info'
                         : b.coverage_type === 'partial' ? 'warn' : 'muted';
        %>
          <tr>
            <td><strong><%= b.process_name %></strong></td>
            <td><%= b.department || '—' %></td>
            <td><span class="badge <%= critCls %>"><%= crit %></span></td>
            <td><%= b.rto_hours != null ? b.rto_hours + ' hrs' : '—' %></td>
            <td><%= b.rpo_hours != null ? b.rpo_hours + ' hrs' : '—' %></td>
            <td><span class="badge <%= ccls %>"><%= b.coverage_type %></span></td>
            <td class="right"><a href="/bia/<%= b.id %>">Open process</a></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>

<div class="card">
  <div class="card-head"><div class="card-title">Plan content</div></div>
  <div class="md-content"><%- renderMarkdown(plan.content || '') %></div>
</div>
