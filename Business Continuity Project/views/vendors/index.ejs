<div class="page-head">
  <div>
    <h1>Vendors & Third Parties</h1>
    <p>Track critical suppliers, concentration risk, SLAs, and contract renewals.</p>
  </div>
  <div class="actions"><a class="btn primary" href="/vendors/new">+ Add vendor</a></div>
</div>

<div class="grid grid-4" style="margin-bottom:16px;">
  <div class="card kpi"><div class="kpi-label">Total vendors</div><div class="kpi-value"><%= stats.total %></div></div>
  <div class="card kpi"><div class="kpi-label">Critical</div><div class="kpi-value"><%= stats.critical %></div></div>
  <div class="card kpi"><div class="kpi-label">Tier 1</div><div class="kpi-value"><%= stats.tier1 %></div></div>
  <div class="card kpi"><div class="kpi-label">Due for review</div><div class="kpi-value"><%= stats.dueForReview %></div></div>
</div>

<div class="card">
  <% if (rows.length === 0) { %>
    <p class="muted" style="padding:20px 0;">No vendors yet. Add your first supplier to begin tracking third-party risk.</p>
  <% } else { %>
    <table class="table">
      <thead>
        <tr>
          <th>Vendor</th><th>Category</th><th>Tier</th>
          <th>Risk</th><th>Criticality</th><th>Owner</th>
          <th>Next review</th><th>Status</th><th></th>
        </tr>
      </thead>
      <tbody>
        <% rows.forEach(v => {
           const critCls = v.criticality === 'Critical' ? 'danger' : (v.criticality === 'High' ? 'warn' : (v.criticality === 'Medium' ? 'info' : 'muted'));
           const statusCls = v.status === 'offboarded' ? 'muted' : (v.status === 'review' ? 'warn' : 'success');
        %>
          <tr>
            <td><strong><%= v.name %></strong><% if (v.service_provided) { %><div class="muted" style="font-size:12px;"><%= v.service_provided %></div><% } %></td>
            <td><%= v.category || '—' %></td>
            <td><span class="badge info">Tier <%= v.tier %></span></td>
            <td><span class="badge <%= critCls %>"><%= v.risk_score %></span></td>
            <td><span class="badge <%= critCls %>"><%= v.criticality %></span></td>
            <td><%= v.owner || '—' %></td>
            <td><%= v.next_review || '—' %></td>
            <td><span class="badge <%= statusCls %>"><%= v.status %></span></td>
            <td class="right"><a href="/vendors/<%= v.id %>">Open</a></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>
