<div class="page-head">
  <div>
    <a href="/dependencies" class="muted">&larr; Dependency graph</a>
    <h1>Impact: <%= root.name %></h1>
    <p><span class="badge info" style="text-transform:capitalize;"><%= root.node_type %></span>
      <% if (root.criticality) { %> · <span class="badge <%= root.criticality === 'Critical' ? 'danger' : (root.criticality === 'High' ? 'warn' : 'muted') %>"><%= root.criticality %></span><% } %>
      <% if (root.description) { %> · <%= root.description %><% } %>
    </p>
  </div>
  <div class="actions">
    <% if (['admin','manager'].includes(user.role)) { %>
      <a class="btn" href="/dependencies/nodes/<%= root.id %>/edit">Edit node</a>
    <% } %>
  </div>
</div>

<div class="grid grid-2">
  <div class="card">
    <div class="card-head"><div class="card-title">Downstream impact</div><span class="muted" style="font-size:12px;">If <%= root.name %> fails, these are affected</span></div>
    <% if (downstream.length <= 1) { %>
      <p class="muted" style="padding:14px 0;">Nothing downstream. This node has no outgoing edges.</p>
    <% } else { %>
      <% downstream.forEach((lvl, i) => { if (i === 0) return; %>
        <div style="margin-bottom:10px;">
          <div class="muted" style="font-size:12px; margin-bottom:4px;">Level <%= i %></div>
          <% lvl.forEach(step => { %>
            <div class="list-row">
              <div class="avatar" style="background:#b3553f; color:#fff;">!</div>
              <div class="body">
                <div class="title"><a href="/dependencies/impact/<%= step.node.id %>"><%= step.node.name %></a> <span class="muted" style="font-size:12px;">(<%= step.node.node_type %>)</span></div>
                <div class="sub">via <em><%= step.edge.label %></em> · strength <%= step.edge.strength %></div>
              </div>
            </div>
          <% }) %>
        </div>
      <% }) %>
    <% } %>
  </div>

  <div class="card">
    <div class="card-head"><div class="card-title">Upstream dependencies</div><span class="muted" style="font-size:12px;">What <%= root.name %> relies on</span></div>
    <% if (upstream.length <= 1) { %>
      <p class="muted" style="padding:14px 0;">No upstream dependencies recorded.</p>
    <% } else { %>
      <% upstream.forEach((lvl, i) => { if (i === 0) return; %>
        <div style="margin-bottom:10px;">
          <div class="muted" style="font-size:12px; margin-bottom:4px;">Level <%= i %></div>
          <% lvl.forEach(step => { %>
            <div class="list-row">
              <div class="avatar" style="background:#4a75a8; color:#fff;">&uarr;</div>
              <div class="body">
                <div class="title"><a href="/dependencies/impact/<%= step.node.id %>"><%= step.node.name %></a> <span class="muted" style="font-size:12px;">(<%= step.node.node_type %>)</span></div>
                <div class="sub">via <em><%= step.edge.label %></em> · strength <%= step.edge.strength %></div>
              </div>
            </div>
          <% }) %>
        </div>
      <% }) %>
    <% } %>
  </div>
</div>
