<aside class="sidebar">
  <a class="brand" href="/dashboard">
    <img class="brand-logo-img" src="/img/logo.svg" alt="BCM Sentinel" />
    <span class="brand-stack">
      <span class="brand-text">BCM Sentinel</span>
      <span class="brand-tagline">By Ali Moyo</span>
    </span>
  </a>

  <nav>
    <a class="nav-item <%= currentPath === '/dashboard' ? 'active' : '' %>" href="/dashboard">
      <span class="icon">&#9638;</span><span class="nav-label">Home</span>
    </a>
    <a class="nav-item <%= currentPath.startsWith('/bia') ? 'active' : '' %>" href="/bia">
      <span class="icon">&#128196;</span><span class="nav-label">Business Impact</span>
    </a>
    <a class="nav-item <%= currentPath.startsWith('/risks') ? 'active' : '' %>" href="/risks">
      <span class="icon">&#9888;</span><span class="nav-label">Risk Register</span>
    </a>
    <a class="nav-item <%= currentPath.startsWith('/bcp') ? 'active' : '' %>" href="/bcp">
      <span class="icon">&#128220;</span><span class="nav-label">Continuity Plans</span>
    </a>
    <a class="nav-item <%= currentPath.startsWith('/coverage') ? 'active' : '' %>" href="/coverage">
      <span class="icon">&#128208;</span><span class="nav-label">Coverage Map</span>
    </a>
    <a class="nav-item <%= currentPath.startsWith('/incidents') ? 'active' : '' %>" href="/incidents">
      <span class="icon">&#128680;</span><span class="nav-label">Incidents</span>
    </a>

    <div class="section-heading">Resilience</div>
    <a class="nav-item <%= currentPath.startsWith('/vendors') ? 'active' : '' %>" href="/vendors">
      <span class="icon">&#127970;</span><span class="nav-label">Vendors</span>
    </a>
    <a class="nav-item <%= currentPath.startsWith('/exercises') ? 'active' : '' %>" href="/exercises">
      <span class="icon">&#127919;</span><span class="nav-label">Exercises</span>
    </a>
    <a class="nav-item <%= currentPath.startsWith('/compliance') ? 'active' : '' %>" href="/compliance">
      <span class="icon">&#128203;</span><span class="nav-label">Compliance</span>
    </a>
    <a class="nav-item <%= currentPath.startsWith('/audit') ? 'active' : '' %>" href="/audit">
      <span class="icon">&#128269;</span><span class="nav-label">Audit Log</span>
    </a>
    <a class="nav-item <%= currentPath.startsWith('/reports') ? 'active' : '' %>" href="/reports">
      <span class="icon">&#128202;</span><span class="nav-label">Board Reports</span>
    </a>

    <div class="section-heading">People & Knowledge</div>
    <a class="nav-item <%= currentPath.startsWith('/training') ? 'active' : '' %>" href="/training">
      <span class="icon">&#127891;</span><span class="nav-label">Training</span>
    </a>
    <a class="nav-item <%= currentPath.startsWith('/documents') ? 'active' : '' %>" href="/documents">
      <span class="icon">&#128193;</span><span class="nav-label">Document Q&A</span>
    </a>
    <a class="nav-item <%= currentPath.startsWith('/dependencies') ? 'active' : '' %>" href="/dependencies">
      <span class="icon">&#128279;</span><span class="nav-label">Dependency Graph</span>
    </a>

    <div class="section-heading">AI Copilot</div>
    <a class="nav-item <%= currentPath.startsWith('/chatbot') ? 'active' : '' %>" href="/chatbot">
      <span class="icon">&#128172;</span><span class="nav-label">BCM Chatbot</span>
    </a>
    <a class="nav-item <%= currentPath.startsWith('/plan-generator') ? 'active' : '' %>" href="/plan-generator">
      <span class="icon">&#10024;</span><span class="nav-label">Plan Generator</span>
    </a>
  </nav>

  <div class="user-card">
    <div class="user-avatar"><%= (user.name || 'U').split(' ').map(n => n[0]).slice(0,2).join('').toUpperCase() %></div>
    <div class="user-info">
      <div class="name"><%= user.name %></div>
      <div class="email"><%= user.email %></div>
    </div>
  </div>

  <div class="bottom-links">
    <a class="nav-item <%= currentPath.startsWith('/settings') ? 'active' : '' %>" href="/settings">
      <span class="icon">&#9881;</span><span class="nav-label">Settings</span>
    </a>
    <form action="/logout" method="POST" style="margin:0;">
      <button type="submit" class="nav-item" style="background:transparent;border:none;color:inherit;width:100%;text-align:left;padding:10px 12px;">
        <span class="icon">&#x21AA;</span><span class="nav-label">Log out</span>
      </button>
    </form>
  </div>
</aside>
