<div class="page-head">
  <div>
    <a href="/documents" class="muted">&larr; Documents</a>
    <h1>Upload document</h1>
    <p>Paste the text of a plan, policy, or runbook. We'll chunk and index it for Q&A.</p>
  </div>
</div>

<form method="POST" action="/documents" class="card stack-16">
  <div class="form-row cols-2">
    <div><label>Title *</label><input name="title" required placeholder="e.g. Datacenter failover runbook" value="<%= doc?.title || '' %>"/></div>
    <div><label>Kind</label>
      <select name="source_kind">
        <% ['plan','policy','runbook','contract','playbook','other'].forEach(k => { %>
          <option value="<%= k %>" <%= (doc?.source_kind || 'plan') === k ? 'selected' : '' %>><%= k %></option>
        <% }) %>
      </select>
    </div>
  </div>

  <div class="form-row cols-2">
    <div><label>Linked continuity plan (optional)</label>
      <select name="linked_plan_id">
        <option value="">— none —</option>
        <% plans.forEach(p => { %>
          <option value="<%= p.id %>" <%= doc?.linked_plan_id == p.id ? 'selected' : '' %>><%= p.title %></option>
        <% }) %>
      </select>
    </div>
    <div><label>Tags (comma-separated)</label><input name="tags" placeholder="network, dr, aws" value="<%= doc?.tags || '' %>"/></div>
  </div>

  <div>
    <label>Content * (paste the full text — Markdown or plain text both work)</label>
    <textarea name="content" rows="22" required placeholder="# Plan title&#10;## Purpose&#10;…"><%= doc?.content || '' %></textarea>
    <p class="muted" style="font-size:12px; margin-top:6px;">
      We split the text into ~600-character chunks with sentence-aware boundaries and overlap, then index every chunk for
      BM25-style retrieval. If you have an AI key configured, answers are generated by your chosen provider.
    </p>
  </div>

  <div style="display:flex; gap:10px;">
    <button class="btn primary" type="submit">Upload & index</button>
    <a class="btn ghost" href="/documents">Cancel</a>
  </div>
</form>
