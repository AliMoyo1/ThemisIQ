# ─────────────────────────────────────────────────────────────────────────────
# Data Protection Sentinel — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values before starting the app.

# ── AI Provider ──────────────────────────────────────────────────────────────
# Choose: anthropic | openai | gemini
AI_PROVIDER=anthropic

# ── Anthropic (Claude) ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-6

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Google Gemini ────────────────────────────────────────────────────────────
GEMINI_API_KEY=...
GEMINI_MODEL=gemini-1.5-pro

# ── App Config ───────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-secret-string
DATABASE_PATH=sentinel.db
PORT=5000
FLASK_DEBUG=false
