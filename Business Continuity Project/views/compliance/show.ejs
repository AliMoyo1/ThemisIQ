<div class="page-head">
  <div>
    <h1><%= control.clause %> · <%= control.title %></h1>
    <p><%= control.framework %></p>
  </div>
  <div class="actions"><a class="btn ghost" href="/compliance?framework=<%= encodeURIComponent(control.framework) %>">Back to framework</a></div>
</div>

<div class="grid grid-2">
  <div class="card">
    <div class="card-head"><div class="card-title">Description</div></div>
    <p style="white-space:pre-wrap;"><%= control.description || '—' %></p>
  </div>

  <div class="card">
    <div class="card-head"><div class="card-title">Control state</div></div>
    <form method="POST" action="/compliance/<%= control.id %>" class="stack-10">
      <div class="form-row cols-2">
        <div><label>Status</label>
          <select name="status">
            <% STATUSES.forEach(s => { %>
              <option value="<%= s %>" <%= control.status === s ? 'selected' : '' %>><%= s.replace('_',' ') %></option>
            <% }) %>
          </select>
        </div>
        <div><label>Owner</label><input name="owner" value="<%= control.owner || '' %>"/></div>
      </div>
      <div class="form-row cols-2">
        <div><label>Last reviewed</label><input type="date" name="last_reviewed" value="<%= control.last_reviewed || '' %>"/></div>
        <div><label>Next review</label><input type="date" name="next_review" value="<%= control.next_review || '' %>"/></div>
      </div>
      <div><label>Evidence notes</label><textarea name="evidence_notes" rows="4" placeholder="Summary of how this control is evidenced"><%= control.evidence_notes || '' %></textarea></div>
      <button class="btn primary" type="submit">Save</button>
    </form>
  </div>
</div>

<div class="card" style="margin-top:16px;">
  <div class="card-head"><div class="card-title">Evidence repository</div></div>
  <% if (evidence.length === 0) { %>
    <p class="muted">No evidence attached yet.</p>
  <% } else { %>
    <table class="table">
      <thead><tr><th>Title</th><th>Reference</th><th>Notes</th><th>Added by</th><th>When</th><th></th></tr></thead>
      <tbody>
        <% evidence.forEach(e => { %>
          <tr>
            <td><strong><%= e.title %></strong></td>
            <td><% if (e.ref_url) { %><a href="<%= e.ref_url %>" target="_blank" rel="noreferrer"><%= e.ref_url %></a><% } else { %>—<% } %></td>
            <td><%= e.notes || '—' %></td>
            <td><%= e.uploaded_by || '—' %></td>
            <td><%= e.created_at %></td>
            <td class="right">
              <form method="POST" action="/compliance/<%= control.id %>/evidence/<%= e.id %>/delete" data-confirm="Remove this evidence?" style="display:inline;">
                <button class="btn small danger" type="submit">Remove</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>

  <div style="margin-top:18px;">
    <div class="card-title" style="margin-bottom:10px;">Attach evidence</div>
    <form method="POST" action="/compliance/<%= control.id %>/evidence" class="stack-10">
      <div class="form-row cols-2">
        <div><label>Title *</label><input name="title" required placeholder="e.g. BCMS policy v1.2"/></div>
        <div><label>Reference URL</label><input name="ref_url" placeholder="Link to document store"/></div>
      </div>
      <div><label>Notes</label><textarea name="notes" rows="2"></textarea></div>
      <button class="btn primary" type="submit">Attach</button>
    </form>
  </div>
</div>
