<div class="page-head">
  <div>
    <h1><span class="badge severity-<%= incident.severity %>" style="margin-right:8px; font-size:14px; padding:4px 12px;"><%= incident.severity %></span><%= incident.title %></h1>
    <p>Commander: <strong><%= incident.commander || 'Unassigned' %></strong> · Started <%= incident.started_at %> · Status: <%= incident.status %></p>
  </div>
  <div class="actions">
    <a class="btn" href="/incidents/<%= incident.id %>">Classic view</a>
    <a class="btn" href="/incidents/<%= incident.id %>/edit">Edit</a>
    <a class="btn ghost" href="/incidents">Back</a>
  </div>
</div>

<div class="grid grid-3" style="margin-bottom:16px;">
  <div class="kpi">
    <div class="k-label">Open actions</div>
    <div class="k-value"><%= actions.filter(a => a.status !== 'done').length %>/<%= actions.length %></div>
    <div class="k-delta"><%= actions.filter(a => a.priority === 'critical' && a.status !== 'done').length %> critical open</div>
  </div>
  <div class="kpi">
    <div class="k-label">Stakeholders reached</div>
    <div class="k-value"><%= stakeholders.filter(s => s.ack_at).length %>/<%= stakeholders.length %></div>
    <div class="k-delta"><%= stakeholders.filter(s => s.notified_at && !s.ack_at).length %> awaiting ack</div>
  </div>
  <div class="kpi">
    <div class="k-label">Decisions logged</div>
    <div class="k-value"><%= decisions.length %></div>
    <div class="k-delta"><%= linkedPlans.length %> linked plan<%= linkedPlans.length === 1 ? '' : 's' %></div>
  </div>
</div>

<!-- ========== Row 1: Linked plans + AI suggestions ========== -->
<div class="grid grid-2" style="margin-bottom:16px;">
  <div class="card">
    <div class="card-head">
      <div class="card-title">Linked continuity plan<%= linkedPlans.length === 1 ? '' : 's' %></div>
    </div>

    <% if (linkedPlans.length === 0) { %>
      <p class="muted" style="margin-bottom:12px;">No plan linked yet. Link the playbook that governs this disruption so the whole team works off the same script.</p>
    <% } %>

    <% linkedPlans.forEach(p => { %>
      <div style="border:1px solid var(--border); border-radius:10px; padding:12px; margin-bottom:12px;">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:8px;">
          <div>
            <strong><%= p.title %></strong> <span class="muted">v<%= p.version %> · <%= p.status %></span><br>
            <span class="muted" style="font-size:12px;">Owner: <%= p.owner || '—' %> · Scope: <%= p.scope || '—' %></span>
          </div>
          <div style="display:flex; gap:6px;">
            <a class="btn small" href="/bcp/<%= p.id %>" target="_blank">Open</a>
            <form method="POST" action="/incidents/<%= incident.id %>/plan-links/<%= p.id %>/delete" style="display:inline;">
              <button class="btn small ghost" type="submit">Unlink</button>
            </form>
          </div>
        </div>
        <details>
          <summary style="cursor:pointer; color:var(--text-secondary); font-size:12.5px;">Inline plan content</summary>
          <div class="md-content" style="max-height:260px; overflow:auto; padding:8px; border-top:1px solid var(--border); margin-top:8px;">
            <%- renderMarkdown(p.content || '_No content_') %>
          </div>
        </details>
      </div>
    <% }) %>

    <% if (availablePlans.length) { %>
      <form method="POST" action="/incidents/<%= incident.id %>/plan-links" style="display:flex; gap:8px; align-items:center;">
        <select name="plan_id" required style="flex:1;">
          <option value="">Link another plan…</option>
          <% availablePlans.forEach(p => { %>
            <option value="<%= p.id %>"><%= p.title %> (v<%= p.version %>)</option>
          <% }) %>
        </select>
        <button class="btn primary small" type="submit">Link</button>
      </form>
    <% } %>
  </div>

  <div class="card">
    <div class="card-head">
      <div class="card-title">AI Copilot — next-step recommender</div>
    </div>
    <p class="muted" style="margin-bottom:12px; font-size:13px;">
      Reads the incident, your timeline, decisions, action board, and any linked plan — then recommends the next 5–7 moves for the response team. Output is posted into the timeline so the whole room sees it.
    </p>
    <form method="POST" action="/incidents/<%= incident.id %>/ai-suggest" data-ai="Reviewing your incident and linked plans — drafting next steps…">
      <button class="btn primary" type="submit">Suggest next 60 minutes</button>
    </form>

    <div style="margin-top:16px; border-top:1px solid var(--border); padding-top:12px;">
      <div style="font-weight:600; font-size:13px; margin-bottom:8px;">Post an update to the timeline</div>
      <form method="POST" action="/incidents/<%= incident.id %>/updates" class="stack-10">
        <input type="hidden" name="redirect" value="/incidents/<%= incident.id %>/command">
        <textarea name="note" placeholder="What just happened? Who did what?" required rows="2"></textarea>
        <button class="btn primary small" type="submit">Post update</button>
      </form>
    </div>
  </div>
</div>

<!-- ========== Row 2: Action board + Decision log ========== -->
<div class="grid grid-2" style="margin-bottom:16px;">
  <div class="card">
    <div class="card-head">
      <div class="card-title">Action board</div>
    </div>

    <form method="POST" action="/incidents/<%= incident.id %>/actions" class="stack-10" style="margin-bottom:14px;">
      <input type="text" name="title" placeholder="Action item (e.g. Restore DB from last known-good snapshot)" required>
      <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:8px;">
        <input type="text" name="owner" placeholder="Owner">
        <select name="priority">
          <option value="normal">Normal</option>
          <option value="low">Low</option>
          <option value="high">High</option>
          <option value="critical">Critical</option>
        </select>
        <input type="datetime-local" name="due_at">
      </div>
      <button class="btn primary small" type="submit">Add action</button>
    </form>

    <% if (actions.length === 0) { %>
      <p class="muted">No actions yet. Capture what needs to happen and who's on it.</p>
    <% } %>
    <% actions.forEach(a => { %>
      <div class="list-row" style="align-items:flex-start;">
        <div style="flex:1; min-width:0;">
          <div style="display:flex; gap:6px; align-items:center; flex-wrap:wrap;">
            <% if (a.priority === 'critical') { %><span class="badge danger">CRITICAL</span>
            <% } else if (a.priority === 'high') { %><span class="badge warn">HIGH</span>
            <% } else if (a.priority === 'low') { %><span class="badge muted">LOW</span><% } %>
            <span class="badge <%= a.status === 'done' ? 'success' : (a.status === 'blocked' ? 'danger' : (a.status === 'in_progress' ? 'info' : 'muted')) %>"><%= a.status.replace('_',' ') %></span>
            <strong style="<%= a.status === 'done' ? 'text-decoration:line-through; color:var(--text-muted);' : '' %>"><%= a.title %></strong>
          </div>
          <div class="muted" style="font-size:12px; margin-top:4px;">
            <%= a.owner || 'Unassigned' %>
            <% if (a.due_at) { %> · due <%= a.due_at %><% } %>
            · added by <%= a.created_by || '—' %>
          </div>
        </div>
        <div style="display:flex; gap:4px; flex-shrink:0;">
          <form method="POST" action="/incidents/<%= incident.id %>/actions/<%= a.id %>" style="display:inline;">
            <select name="status" onchange="this.form.submit()" style="font-size:12px; padding:4px 8px;">
              <option value="open" <%= a.status === 'open' ? 'selected' : '' %>>Open</option>
              <option value="in_progress" <%= a.status === 'in_progress' ? 'selected' : '' %>>In progress</option>
              <option value="blocked" <%= a.status === 'blocked' ? 'selected' : '' %>>Blocked</option>
              <option value="done" <%= a.status === 'done' ? 'selected' : '' %>>Done</option>
            </select>
          </form>
          <form method="POST" action="/incidents/<%= incident.id %>/actions/<%= a.id %>/delete" style="display:inline;" data-confirm="Remove this action?">
            <button class="btn small ghost" type="submit" title="Remove">✕</button>
          </form>
        </div>
      </div>
    <% }) %>
  </div>

  <div class="card">
    <div class="card-head">
      <div class="card-title">Decision log</div>
    </div>

    <form method="POST" action="/incidents/<%= incident.id %>/decisions" class="stack-10" style="margin-bottom:14px;">
      <input type="text" name="decision" placeholder="Decision (e.g. Failover to DR region now)" required>
      <textarea name="rationale" placeholder="Why — what options were weighed, what tipped it" rows="2"></textarea>
      <button class="btn primary small" type="submit">Log decision</button>
    </form>

    <% if (decisions.length === 0) { %>
      <p class="muted">No decisions logged yet. Capture the big calls — regulators ask for this in the post-mortem.</p>
    <% } %>
    <% decisions.forEach(d => { %>
      <div class="list-row" style="align-items:flex-start;">
        <div style="flex:1; min-width:0;">
          <div class="title"><strong><%= d.decision %></strong></div>
          <% if (d.rationale) { %><div class="sub" style="margin-top:4px;"><%= d.rationale %></div><% } %>
          <div class="muted" style="font-size:12px; margin-top:4px;"><%= d.decided_by || 'Unknown' %> · <%= d.decided_at %></div>
        </div>
        <form method="POST" action="/incidents/<%= incident.id %>/decisions/<%= d.id %>/delete" style="display:inline;" data-confirm="Remove this decision?">
          <button class="btn small ghost" type="submit">✕</button>
        </form>
      </div>
    <% }) %>
  </div>
</div>

<!-- ========== Row 3: Stakeholders + Timeline ========== -->
<div class="grid grid-2" style="margin-bottom:16px;">
  <div class="card">
    <div class="card-head">
      <div class="card-title">Stakeholder notifications</div>
    </div>

    <form method="POST" action="/incidents/<%= incident.id %>/stakeholders" class="stack-10" style="margin-bottom:14px;">
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:8px;">
        <input type="text" name="role" placeholder="Role (e.g. Executive sponsor)" required>
        <input type="text" name="person" placeholder="Person / contact">
      </div>
      <div style="display:grid; grid-template-columns:1fr 2fr; gap:8px;">
        <select name="channel">
          <option value="">Channel…</option>
          <option value="phone">Phone</option>
          <option value="email">Email</option>
          <option value="slack">Slack</option>
          <option value="in-person">In-person</option>
          <option value="sms">SMS</option>
        </select>
        <input type="text" name="notes" placeholder="Message / notes">
      </div>
      <button class="btn primary small" type="submit">Add stakeholder</button>
    </form>

    <% if (stakeholders.length === 0) { %>
      <p class="muted">No stakeholders yet. Pre-populate from your comms matrix so nobody gets missed.</p>
    <% } %>
    <% stakeholders.forEach(s => { %>
      <div class="list-row" style="align-items:flex-start;">
        <div style="flex:1; min-width:0;">
          <div class="title"><strong><%= s.role %></strong><% if (s.person) { %> — <%= s.person %><% } %></div>
          <div class="muted" style="font-size:12px; margin-top:2px;">
            <% if (s.channel) { %><%= s.channel %> · <% } %>
            <% if (s.ack_at) { %><span style="color:var(--success); font-weight:600;">Acknowledged</span> <%= s.ack_at %>
            <% } else if (s.notified_at) { %><span style="color:var(--accent-strong); font-weight:600;">Notified</span> <%= s.notified_at %>
            <% } else { %><span class="muted">Not contacted</span><% } %>
          </div>
          <% if (s.notes) { %><div style="font-size:12px; margin-top:4px;"><%= s.notes %></div><% } %>
        </div>
        <div style="display:flex; gap:4px; flex-shrink:0; flex-wrap:wrap; justify-content:flex-end;">
          <% if (!s.notified_at) { %>
            <form method="POST" action="/incidents/<%= incident.id %>/stakeholders/<%= s.id %>" style="display:inline;">
              <input type="hidden" name="mark" value="notified">
              <button class="btn small" type="submit">Notified</button>
            </form>
          <% } %>
          <% if (s.notified_at && !s.ack_at) { %>
            <form method="POST" action="/incidents/<%= incident.id %>/stakeholders/<%= s.id %>" style="display:inline;">
              <input type="hidden" name="mark" value="ack">
              <button class="btn small primary" type="submit">Ack'd</button>
            </form>
          <% } %>
          <% if (s.notified_at || s.ack_at) { %>
            <form method="POST" action="/incidents/<%= incident.id %>/stakeholders/<%= s.id %>" style="display:inline;">
              <input type="hidden" name="mark" value="reset">
              <button class="btn small ghost" type="submit">Reset</button>
            </form>
          <% } %>
          <form method="POST" action="/incidents/<%= incident.id %>/stakeholders/<%= s.id %>/delete" style="display:inline;" data-confirm="Remove this stakeholder?">
            <button class="btn small ghost" type="submit">✕</button>
          </form>
        </div>
      </div>
    <% }) %>
  </div>

  <div class="card">
    <div class="card-head">
      <div class="card-title">Timeline</div>
      <div class="card-subtitle"><%= updates.length %> updates</div>
    </div>
    <% if (updates.length === 0) { %>
      <p class="muted">Timeline is empty. Post the first update above.</p>
    <% } %>
    <div style="max-height:520px; overflow:auto;">
      <% updates.forEach(u => { %>
        <div class="list-row" style="align-items:flex-start;">
          <div class="avatar" style="<%= u.author === 'AI Copilot' ? 'background:var(--accent-strong); color:#fff;' : '' %>">
            <%= (u.author || 'S').split(' ').map(n=>n[0]).slice(0,2).join('').toUpperCase() %>
          </div>
          <div class="body">
            <% if (u.author === 'AI Copilot') { %>
              <div class="md-content"><%- renderMarkdown(u.note) %></div>
            <% } else { %>
              <div class="title" style="white-space:pre-wrap;"><%= u.note %></div>
            <% } %>
            <div class="sub"><%= u.author || 'System' %> · <%= u.created_at %></div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</div>
