<div class="page-head">
  <div>
    <a href="/documents" class="muted">&larr; Documents</a>
    <h1><%= doc.title %></h1>
    <p>
      <span class="badge info"><%= doc.source_kind || 'other' %></span>
      · <%= doc.chunk_count %> chunks
      · <%= ((doc.bytes || 0) / 1024).toFixed(1) %> KB
      <% if (doc.plan_title) { %> · linked to <a href="/bcp/<%= doc.linked_plan_id %>"><%= doc.plan_title %></a><% } %>
    </p>
  </div>
  <div class="actions">
    <a class="btn" href="/documents/ask/query?document_id=<%= doc.id %>">Ask this document</a>
    <% if (['admin','manager'].includes(user.role)) { %>
      <form method="POST" action="/documents/<%= doc.id %>/reindex" style="display:inline;"><button class="btn" type="submit">Re-index</button></form>
      <form method="POST" action="/documents/<%= doc.id %>/delete" style="display:inline;" onsubmit="return confirm('Delete this document and its chunks?');"><button class="btn danger" type="submit">Delete</button></form>
    <% } %>
  </div>
</div>

<div class="card" style="margin-bottom:16px;">
  <div class="card-head"><div class="card-title">Full text</div></div>
  <pre style="white-space:pre-wrap; font-family:Inter, sans-serif; font-size:13px; line-height:1.55; max-height:380px; overflow:auto;"><%= doc.content %></pre>
</div>

<div class="card">
  <div class="card-head"><div class="card-title">Indexed chunks <span class="count-chip"><%= chunks.length %></span></div></div>
  <% if (chunks.length === 0) { %>
    <p class="muted" style="padding:16px 0;">No chunks indexed yet. Click Re-index above.</p>
  <% } else { %>
    <% chunks.forEach(c => { %>
      <div class="list-row">
        <div class="avatar">#<%= c.chunk_index %></div>
        <div class="body">
          <div class="title" style="font-size:13px; line-height:1.45;"><%= c.content.slice(0, 420) %><%= c.content.length > 420 ? '…' : '' %></div>
          <div class="sub"><%= c.token_count %> tokens</div>
        </div>
      </div>
    <% }) %>
  <% } %>
</div>
