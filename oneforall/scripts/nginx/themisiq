# ThemisIQ nginx site config.
# Installed to /etc/nginx/sites-enabled/themisiq by deploy.py.
# Rate limiting zones are defined in /etc/nginx/conf.d/themisiq-zones.conf.
#
# themisiq.net / www.themisiq.net - landing page served from /var/www/themisiq
# app.themisiq.net  - orange cloud (Cloudflare proxies HTTPS, we serve HTTP)
# monitor.themisiq.net - grey cloud (direct HTTP, used by UptimeRobot)

# Landing page: bare domain and www redirect.
server {
    listen 80;
    server_name themisiq.net www.themisiq.net;
    root /var/www/themisiq;
    index index.html;
    location / {
        try_files $uri $uri/ =404;
    }
}

server {
    listen 80;
    server_name app.themisiq.net monitor.themisiq.net;

    # WhatsApp bridge webhook endpoints.
    # Bridge runs on port 8001 (themisiq-bridge.service).
    # Meta posts inbound WhatsApp messages to /webhook/whatsapp.
    # ThemisIQ posts proactive alerts to /webhook/themisiq (can also call port 8001 directly).
    location /webhook/ {
        proxy_pass         http://127.0.0.1:8001;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 30s;
    }

    # Health and readiness probes: no rate limit.
    # Used by UptimeRobot and internal checks.
    location = /health {
        proxy_pass         http://127.0.0.1:8080;
        proxy_set_header   Host               $host;
        proxy_set_header   X-Real-IP          $remote_addr;
        proxy_set_header   X-Forwarded-For    $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto  $scheme;
    }

    location = /ready {
        proxy_pass         http://127.0.0.1:8080;
        proxy_set_header   Host               $host;
        proxy_set_header   X-Real-IP          $remote_addr;
        proxy_set_header   X-Forwarded-For    $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto  $scheme;
    }

    # Static assets: no rate limit, long cache.
    location /static/ {
        proxy_pass         http://127.0.0.1:8080;
        proxy_set_header   Host               $host;
        proxy_cache_valid  200 7d;
        expires            7d;
        add_header         Cache-Control "public, immutable";
    }

    # Login: strict per-IP limit only on POST (credential submission).
    # GET (fetching the form) is bypassed by the zone map, so opening the
    # login page never counts against the brute-force budget.
    # Burst 10 gives normal users headroom for retypes; malicious brute force
    # still hits the 20r/m ceiling quickly.
    location = /login {
        limit_req           zone=login burst=10 nodelay;
        limit_req           zone=general burst=50 nodelay;
        proxy_pass          http://127.0.0.1:8080;
        proxy_set_header    Host              $host;
        proxy_set_header    X-Real-IP         $remote_addr;
        proxy_set_header    X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header    X-Forwarded-Proto $scheme;
    }

    # Password change and MFA setup: same POST-only strict limit.
    location ~ ^/(change-password|mfa/) {
        limit_req           zone=login burst=10 nodelay;
        limit_req           zone=general burst=50 nodelay;
        proxy_pass          http://127.0.0.1:8080;
        proxy_set_header    Host              $host;
        proxy_set_header    X-Real-IP         $remote_addr;
        proxy_set_header    X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header    X-Forwarded-Proto $scheme;
    }

    # API endpoints: 30 requests/second, burst 50.
    location /api/ {
        limit_req           zone=api burst=50 nodelay;
        proxy_pass          http://127.0.0.1:8080;
        proxy_set_header    Host              $host;
        proxy_set_header    X-Real-IP         $remote_addr;
        proxy_set_header    X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header    X-Forwarded-Proto $scheme;
        proxy_http_version  1.1;
    }

    # Module API endpoints (e.g. /aria/api/, /erm/api/): same rate limit as /api/,
    # longer timeout for heavy operations like AI auto-mapping.
    location ~ ^/[a-z]+/api/ {
        limit_req            zone=api burst=50 nodelay;
        proxy_pass           http://127.0.0.1:8080;
        proxy_set_header     Host              $host;
        proxy_set_header     X-Real-IP         $remote_addr;
        proxy_set_header     X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header     X-Forwarded-Proto $scheme;
        proxy_http_version   1.1;
        proxy_read_timeout   300s;
    }

    # Everything else: 20 requests/second, burst 50.
    location / {
        limit_req           zone=general burst=50 nodelay;
        proxy_pass          http://127.0.0.1:8080;
        proxy_set_header    Host              $host;
        proxy_set_header    X-Real-IP         $remote_addr;
        proxy_set_header    X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header    X-Forwarded-Proto $scheme;
        proxy_http_version  1.1;
        proxy_set_header    Upgrade           $http_upgrade;
        proxy_set_header    Connection        "upgrade";
    }
}
