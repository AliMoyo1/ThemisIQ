<div class="auth-bg">
  <div class="auth-card">
    <h1>Welcome back</h1>
    <div class="sub">Sign in to your continuity workspace.</div>

    <%- include('../partials/flash') %>

    <form method="POST" action="/login" class="stack-16">
      <div>
        <label>Work email</label>
        <input type="email" name="email" required autofocus />
      </div>
      <div>
        <label>Password</label>
        <input type="password" name="password" required />
      </div>
      <button type="submit" class="btn primary" style="width:100%; justify-content:center;">Sign in</button>
    </form>

    <div class="foot">
      Don't have a workspace? <a href="/signup">Create one</a>.
    </div>
  </div>
</div>
