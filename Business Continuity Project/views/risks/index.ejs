<div class="page-head">
  <div>
    <h1>Risk Register</h1>
    <p>Identify, rate, and track treatment of continuity risks.</p>
  </div>
  <div class="actions"><a class="btn primary" href="/risks/new">+ Log risk</a></div>
</div>

<div class="card">
  <% if (rows.length === 0) { %>
    <p class="muted" style="padding:20px 0;">No risks logged yet.</p>
  <% } else { %>
    <table class="table">
      <thead>
        <tr><th>Title</th><th>Category</th><th>Score</th><th>Treatment</th><th>Owner</th><th>Due</th><th>Status</th><th></th></tr>
      </thead>
      <tbody>
        <% rows.forEach(r => {
           const cls = r.score >= 15 ? 'danger' : (r.score >= 9 ? 'warn' : (r.score >= 4 ? 'info' : 'muted'));
           const statusCls = r.status === 'closed' ? 'success' : (r.status === 'in_progress' ? 'warn' : 'info');
        %>
          <tr>
            <td><strong><%= r.title %></strong></td>
            <td><%= r.category || '—' %></td>
            <td><span class="badge <%= cls %>"><%= r.score %> (<%= r.likelihood %>×<%= r.impact %>)</span></td>
            <td><%= r.treatment %></td>
            <td><%= r.owner || '—' %></td>
            <td><%= r.due_date || '—' %></td>
            <td><span class="badge <%= statusCls %>"><%= r.status %></span></td>
            <td class="right"><a href="/risks/<%= r.id %>">Open</a></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>
