<div class="page-head">
  <div>
    <h1>Good day, <%= user.name.split(' ')[0] %></h1>
    <p>Here's the continuity posture for <strong><%= tenant.name %></strong> today.</p>
  </div>
  <div class="actions">
    <a class="btn" href="/chatbot">Ask the AI copilot</a>
    <a class="btn primary" href="/incidents/new">Declare incident</a>
  </div>
</div>

<!-- KPI row -->
<div class="grid grid-4" style="margin-bottom:16px;">
  <div class="kpi"><div class="k-label">BIA records</div><div class="k-value"><%= kpi.bia %></div><div class="k-delta up">Coverage tracked</div></div>
  <div class="kpi"><div class="k-label">Open risks</div><div class="k-value"><%= kpi.risks_open %></div><div class="k-delta <%= kpi.risks_open > 5 ? 'down' : 'up' %>"><%= kpi.risks_open > 5 ? 'Needs attention' : 'Under control' %></div></div>
  <div class="kpi"><div class="k-label">Active plans</div><div class="k-value"><%= kpi.plans %></div><div class="k-delta up">In library</div></div>
  <div class="kpi"><div class="k-label">Open incidents</div><div class="k-value"><%= kpi.incidents_open %></div><div class="k-delta <%= kpi.incidents_open > 0 ? 'down' : 'up' %>"><%= kpi.incidents_open > 0 ? 'Active response' : 'All clear' %></div></div>
</div>

<!-- Phase 2 KPI row -->
<div class="grid grid-4" style="margin-bottom:16px;">
  <div class="kpi"><div class="k-label">Active vendors</div><div class="k-value"><%= kpi.vendors %></div><div class="k-delta up">Third parties</div></div>
  <div class="kpi"><div class="k-label">Planned exercises</div><div class="k-value"><%= kpi.exercises_planned %></div><div class="k-delta <%= kpi.exercises_planned === 0 ? 'down' : 'up' %>"><%= kpi.exercises_planned === 0 ? 'Schedule one' : 'On the calendar' %></div></div>
  <div class="kpi"><div class="k-label">Verified controls</div><div class="k-value"><%= kpi.controls_verified %></div><div class="k-delta up">Evidence on file</div></div>
  <div class="kpi"><div class="k-label">Compliance maturity</div><div class="k-value"><%= complianceMaturity %>%</div><div class="k-delta <%= complianceMaturity >= 70 ? 'up' : 'down' %>">ISO 22301</div></div>
</div>

<!-- Phase 3 KPI row -->
<div class="grid grid-4" style="margin-bottom:16px;">
  <div class="kpi"><div class="k-label">Training modules</div><div class="k-value"><%= kpi.training_modules %></div><div class="k-delta up">Active</div></div>
  <div class="kpi"><div class="k-label">My outstanding training</div><div class="k-value"><%= myOutstandingTraining %></div><div class="k-delta <%= myOutstandingTraining === 0 ? 'up' : 'down' %>"><%= myOutstandingTraining === 0 ? 'Up to date' : 'Action required' %></div></div>
  <div class="kpi"><div class="k-label">Indexed documents</div><div class="k-value"><%= kpi.documents %></div><div class="k-delta up">Q&A ready</div></div>
  <div class="kpi"><div class="k-label">Dependency nodes</div><div class="k-value"><%= kpi.dep_nodes %></div><div class="k-delta <%= criticalNodes > 0 ? 'down' : 'up' %>"><%= criticalNodes %> critical</div></div>
</div>

<!-- Row: recent activity + upcoming reviews -->
<div class="grid grid-2" style="margin-bottom:16px;">
  <div class="card">
    <div class="card-head">
      <div class="card-title">Recent activity <span class="count-chip"><%= activity.length %></span></div>
      <a class="muted" href="/incidents">View all</a>
    </div>
    <% if (activity.length === 0) { %>
      <p class="muted" style="padding:24px 0;">No activity yet. Create your first BIA, risk, or plan to get started.</p>
    <% } %>
    <% activity.forEach(a => { %>
      <div class="list-row">
        <div class="avatar">
          <%= a.kind === 'risk' ? 'R' : (a.kind === 'incident' ? 'I' : 'P') %>
        </div>
        <div class="body">
          <div class="title"><strong><%= a.kind === 'incident' ? 'Incident' : (a.kind === 'risk' ? 'Risk logged' : 'Plan updated') %>:</strong> <%= a.title %></div>
          <div class="sub"><%= a.created_at %></div>
        </div>
        <div class="actions">
          <a href="/<%= a.kind === 'plan' ? 'bcp' : (a.kind === 'risk' ? 'risks' : 'incidents') %>/<%= a.id %>">View</a>
        </div>
      </div>
    <% }) %>
  </div>

  <div class="card">
    <div class="card-head">
      <div class="card-title">Upcoming plan reviews</div>
      <a class="muted" href="/bcp">All plans</a>
    </div>
    <% if (upcomingReviews.length === 0) { %>
      <p class="muted" style="padding:24px 0;">No reviews scheduled. Set <em>next_review</em> dates on your plans to see them here.</p>
    <% } %>
    <% upcomingReviews.forEach(p => { %>
      <div class="list-row">
        <div class="avatar">PL</div>
        <div class="body">
          <div class="title"><%= p.title %></div>
          <div class="sub">Due <%= p.next_review %></div>
        </div>
        <div class="actions"><a href="/bcp/<%= p.id %>">Review</a></div>
      </div>
    <% }) %>
  </div>
</div>

<!-- Row: pulse + overdue risks -->
<div class="grid grid-2" style="margin-bottom:16px;">
  <div class="card">
    <div class="card-head"><div class="card-title">Continuity pulse</div></div>
    <div class="pulse">
      <div class="pulse-donut" style="--pulse: <%= pulse.overall * 10 %>;">
        <div class="score">
          <div class="big"><%= pulse.overall.toFixed(1) %></div>
          <div class="small">/10</div>
        </div>
      </div>
      <div class="pulse-metrics">
        <div class="metric">
          <div class="m-icon">&#9873;</div>
          <div><span class="m-value"><%= pulse.plan_coverage.toFixed(1) %></span> <span class="m-arrow up">&uarr;</span><br><span class="m-label">Plan coverage</span></div>
        </div>
        <div class="metric">
          <div class="m-icon">&#9888;</div>
          <div><span class="m-value"><%= pulse.risk_posture.toFixed(1) %></span> <span class="m-arrow <%= pulse.risk_posture < 6 ? 'down' : 'up' %>"><%= pulse.risk_posture < 6 ? '&darr;' : '&uarr;' %></span><br><span class="m-label">Risk posture</span></div>
        </div>
        <div class="metric">
          <div class="m-icon">&#128680;</div>
          <div><span class="m-value"><%= pulse.incident_health.toFixed(1) %></span> <span class="m-arrow up">&uarr;</span><br><span class="m-label">Incident health</span></div>
        </div>
        <div class="metric">
          <div class="m-icon">&#128336;</div>
          <div><span class="m-value"><%= pulse.review_freshness.toFixed(1) %></span> <span class="m-arrow up">&uarr;</span><br><span class="m-label">Review freshness</span></div>
        </div>
        <div class="metric">
          <div class="m-icon">&#128202;</div>
          <div><span class="m-value"><%= pulse.bia_coverage.toFixed(1) %></span> <span class="m-arrow up">&uarr;</span><br><span class="m-label">BIA coverage</span></div>
        </div>
        <div class="metric">
          <div class="m-icon">&#128737;</div>
          <div><span class="m-value"><%= pulse.readiness.toFixed(1) %></span> <span class="m-arrow up">&uarr;</span><br><span class="m-label">Readiness</span></div>
        </div>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-head">
      <div class="card-title">Overdue risk mitigations</div>
      <a class="muted" href="/risks">Risk register</a>
    </div>
    <% if (overdueRisks.length === 0) { %>
      <p class="muted" style="padding:24px 0;">Nothing overdue. Great discipline.</p>
    <% } %>
    <% overdueRisks.forEach(r => { %>
      <div class="list-row">
        <div class="avatar" style="background:linear-gradient(135deg,#f1c6b9,#b3553f); color:#fff;">!</div>
        <div class="body">
          <div class="title"><%= r.title %></div>
          <div class="sub">Due <%= r.due_date %> · owner <%= r.owner || '—' %></div>
        </div>
        <div class="actions"><a href="/risks/<%= r.id %>">Open</a></div>
      </div>
    <% }) %>
  </div>
</div>

<!-- Row: vendors due for review -->
<% if (vendorsDueForReview && vendorsDueForReview.length) { %>
<div class="card" style="margin-bottom:16px;">
  <div class="card-head">
    <div class="card-title">Vendors due for review</div>
    <a class="muted" href="/vendors">All vendors</a>
  </div>
  <% vendorsDueForReview.forEach(v => { %>
    <div class="list-row">
      <div class="avatar">V</div>
      <div class="body">
        <div class="title"><%= v.name %></div>
        <div class="sub">Review due <%= v.next_review %> · <%= v.criticality %></div>
      </div>
      <div class="actions"><a href="/vendors/<%= v.id %>">Open</a></div>
    </div>
  <% }) %>
</div>
<% } %>

<!-- Row: quick actions + support -->
<div class="grid grid-3">
  <div class="card">
    <div class="card-head"><div class="card-title">Quick actions</div></div>
    <div class="stack-10">
      <a class="btn" href="/bia/new">New BIA record</a>
      <a class="btn" href="/risks/new">Log a risk</a>
      <a class="btn" href="/bcp/new">Draft a plan</a>
      <a class="btn" href="/vendors/new">Add vendor</a>
      <a class="btn" href="/exercises/new">Schedule exercise</a>
      <a class="btn" href="/training/new">New training module</a>
      <a class="btn" href="/documents/ask/query">Ask your documents</a>
      <a class="btn" href="/dependencies">Dependency graph</a>
      <a class="btn" href="/plan-generator">AI plan generator</a>
    </div>
  </div>
  <div class="card">
    <div class="card-head"><div class="card-title">AI copilot</div></div>
    <p class="muted">Ask anything about your plans, ISO 22301 controls, or "what do I do if…" scenarios.</p>
    <a class="btn primary" href="/chatbot">Open chatbot</a>
  </div>
  <div class="card">
    <div class="card-head"><div class="card-title">Support</div></div>
    <div class="stack-10">
      <a class="btn" href="/settings">Workspace settings</a>
      <a class="btn" href="/settings#ai">Configure AI keys</a>
      <a class="btn" href="/settings#notifications">Email reminders</a>
    </div>
  </div>
</div>
