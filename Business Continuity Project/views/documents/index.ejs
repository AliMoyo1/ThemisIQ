<div class="page-head">
  <div>
    <h1>Document Q&A</h1>
    <p>Upload BCP plans, policies, and runbooks — then ask the AI copilot questions against them.</p>
  </div>
  <div class="actions">
    <a class="btn" href="/documents/ask/query">Ask a question</a>
    <% if (['admin','manager','responder'].includes(user.role)) { %>
      <a class="btn primary" href="/documents/new">+ Upload document</a>
    <% } %>
  </div>
</div>

<div class="grid grid-4" style="margin-bottom:16px;">
  <div class="card kpi"><div class="kpi-label">Documents</div><div class="kpi-value"><%= stats.docs %></div></div>
  <div class="card kpi"><div class="kpi-label">Indexed chunks</div><div class="kpi-value"><%= stats.chunks %></div></div>
  <div class="card kpi"><div class="kpi-label">Storage</div><div class="kpi-value"><%= (stats.bytes / 1024).toFixed(1) %><span style="font-size:14px;"> KB</span></div></div>
  <div class="card kpi"><div class="kpi-label">Queries run</div><div class="kpi-value"><%= stats.queries %></div></div>
</div>

<div class="grid grid-2">
  <div class="card">
    <div class="card-head"><div class="card-title">Library</div></div>
    <% if (docs.length === 0) { %>
      <p class="muted" style="padding:18px 0;">No documents yet. Upload your first plan or policy to start asking questions.</p>
    <% } else { %>
      <table class="table">
        <thead><tr><th>Title</th><th>Kind</th><th>Chunks</th><th>Linked plan</th><th>Uploaded</th><th></th></tr></thead>
        <tbody>
          <% docs.forEach(d => { %>
            <tr>
              <td><strong><%= d.title %></strong><% if (d.filename) { %><div class="muted" style="font-size:12px;"><%= d.filename %></div><% } %></td>
              <td><span class="badge info"><%= d.source_kind || 'other' %></span></td>
              <td><%= d.chunk_count %></td>
              <td><%= d.plan_title || '—' %></td>
              <td class="muted" style="font-size:12px;"><%= d.created_at %></td>
              <td class="right"><a href="/documents/<%= d.id %>">Open</a></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>

  <div class="card">
    <div class="card-head"><div class="card-title">Recent questions</div></div>
    <% if (recentQueries.length === 0) { %>
      <p class="muted" style="padding:18px 0;">No questions asked yet. <a href="/documents/ask/query">Try one now →</a></p>
    <% } %>
    <% recentQueries.forEach(q => { %>
      <div class="list-row">
        <div class="avatar">Q</div>
        <div class="body">
          <div class="title"><%= q.question.slice(0, 90) %><%= q.question.length > 90 ? '…' : '' %></div>
          <div class="sub"><%= q.created_at %> · <%= q.provider %></div>
        </div>
      </div>
    <% }) %>
  </div>
</div>
