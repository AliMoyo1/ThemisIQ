# ThemisIQ — Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── App ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=false
HOST=127.0.0.1
PORT=8080

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default — local dev only):
DB_PATH=data/oneforall.db

# PostgreSQL (production — set DATABASE_URL to switch engines):
# DATABASE_URL=postgresql://themisiq@pgbouncer:5432/themisiq
# PGPASSWORD_FILE=/run/secrets/pg_password   # preferred over inline password
# PGSSLMODE=require                          # enforce TLS on private bridge
# POSTGRES_POOL_MIN=2
# POSTGRES_POOL_MAX=10

# Backup (used by the 02:00 CAT scheduled backup job):
# BACKUP_PATH=data/backups
# BACKUP_RETAIN_DAYS=30
# BACKUP_OFFSITE_RCLONE_REMOTE=r2:themisiq-backups   # Cloudflare R2 via rclone

# ── AI Provider (choose one) ──────────────────────────────────────────────────
AI_PROVIDER=anthropic

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# OpenAI (optional)
# OPENAI_API_KEY=sk-your-key-here

# Google Gemini (optional)
# GEMINI_API_KEY=your-key-here

# DeepSeek (optional)
# DEEPSEEK_API_KEY=your-key-here

# Ollama (optional — local LLM, no key needed)
# OLLAMA_MODEL=llama3.2
# OLLAMA_HOST=http://localhost:11434

# ── Email (optional) ──────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
SMTP_FROM=ThemisIQ <noreply@yourdomain.com>
