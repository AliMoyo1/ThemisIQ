<div class="page-head">
  <div>
    <h1><%= record ? 'Edit BIA record' : 'New BIA record' %></h1>
    <p>Capture the impact if this process is disrupted.</p>
  </div>
  <div class="actions"><a class="btn" href="/bia">Back</a></div>
</div>

<div class="card">
  <form method="POST" action="<%= record ? '/bia/' + record.id : '/bia' %>" class="stack-16">
    <div class="form-row cols-2">
      <div><label>Process name</label><input name="process_name" required value="<%= record ? record.process_name : '' %>" /></div>
      <div><label>Department</label><input name="department" value="<%= record ? record.department || '' : '' %>" /></div>
    </div>
    <div class="form-row cols-2">
      <div><label>Owner</label><input name="owner" value="<%= record ? record.owner || '' : '' %>" /></div>
      <div><label>Dependencies (systems, people, suppliers)</label><input name="dependencies" value="<%= record ? record.dependencies || '' : '' %>" /></div>
    </div>
    <div><label>Description</label><textarea name="description"><%= record ? record.description || '' : '' %></textarea></div>
    <div class="form-row cols-2">
      <div><label>Recovery Time Objective (hours)</label><input type="number" min="0" name="rto_hours" value="<%= record ? record.rto_hours || '' : '' %>" /></div>
      <div><label>Recovery Point Objective (hours)</label><input type="number" min="0" name="rpo_hours" value="<%= record ? record.rpo_hours || '' : '' %>" /></div>
    </div>
    <div class="form-row cols-2">
      <div><label>Financial impact per day ($)</label><input type="number" min="0" step="100" name="financial_impact_per_day" value="<%= record ? record.financial_impact_per_day || '' : '' %>" /></div>
      <div><label>Operational impact (1–5)</label>
        <select name="operational_impact">
          <% for (let i = 1; i <= 5; i++) { %><option value="<%= i %>" <%= record && record.operational_impact === i ? 'selected' : '' %>><%= i %></option><% } %>
        </select>
      </div>
    </div>
    <div class="form-row cols-2">
      <div><label>Reputational impact (1–5)</label>
        <select name="reputational_impact">
          <% for (let i = 1; i <= 5; i++) { %><option value="<%= i %>" <%= record && record.reputational_impact === i ? 'selected' : '' %>><%= i %></option><% } %>
        </select>
      </div>
      <div><label>Regulatory impact (1–5)</label>
        <select name="regulatory_impact">
          <% for (let i = 1; i <= 5; i++) { %><option value="<%= i %>" <%= record && record.regulatory_impact === i ? 'selected' : '' %>><%= i %></option><% } %>
        </select>
      </div>
    </div>

    <div style="border-top:1px solid var(--border); padding-top:16px; margin-top:4px;">
      <label style="display:block; margin-bottom:4px;">Recovery plans covering this process</label>
      <p class="muted" style="font-size:12.5px; margin:0 0 10px 0;">
        Tick the plans that recover this process if it's disrupted. Mark one as <strong>primary</strong> to show that this process is covered. Use <em>secondary</em>, <em>partial</em>, or <em>referenced</em> for supporting plans.
      </p>
      <% if (!plans || !plans.length) { %>
        <p class="muted" style="font-size:13px;">No continuity plans exist yet. <a href="/bcp/new">Create one</a> and come back to link it.</p>
      <% } else {
           const linkedMap = {};
           (links || []).forEach(l => { linkedMap[l.plan_id] = l.coverage_type || 'primary'; });
      %>
        <div style="display:flex; flex-direction:column; gap:6px; max-height:280px; overflow:auto; border:1px solid var(--border); border-radius:8px; padding:8px;">
          <% plans.forEach(p => {
               const checked = linkedMap.hasOwnProperty(p.id);
               const current = linkedMap[p.id] || 'primary';
          %>
            <div style="display:grid; grid-template-columns:22px 1fr 160px; align-items:center; gap:10px; padding:6px 4px;">
              <input type="checkbox" name="plan_ids" value="<%= p.id %>" <%= checked ? 'checked' : '' %> />
              <div style="font-size:13.5px;">
                <strong><%= p.title %></strong>
                <span class="muted" style="font-size:12px;"> · v<%= p.version || '1.0' %> · <%= p.status || 'draft' %><% if (p.owner) { %> · <%= p.owner %><% } %></span>
              </div>
              <select name="coverage_for_plan_<%= p.id %>" style="font-size:12.5px; padding:4px 6px;">
                <% ['primary','secondary','partial','referenced'].forEach(t => { %>
                  <option value="<%= t %>" <%= current === t ? 'selected' : '' %>><%= t %></option>
                <% }) %>
              </select>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <div class="flex gap-8">
      <button class="btn primary" type="submit"><%= record ? 'Save changes' : 'Create record' %></button>
      <a class="btn" href="/bia">Cancel</a>
    </div>
  </form>
</div>
