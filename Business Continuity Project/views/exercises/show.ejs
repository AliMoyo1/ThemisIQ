<div class="page-head">
  <div>
    <h1><%= exercise.title %></h1>
    <p><%= exercise.type %> · <%= exercise.scheduled_date || 'unscheduled' %><% if (exercise.plan_title) { %> · linked to "<%= exercise.plan_title %>"<% } %></p>
  </div>
  <div class="actions">
    <a class="btn ghost" href="/exercises/<%= exercise.id %>/edit">Edit</a>
    <a class="btn primary" href="/exercises/<%= exercise.id %>/export.docx">Export to Word</a>
    <form method="POST" action="/exercises/<%= exercise.id %>/delete" data-confirm="Remove this exercise?" style="display:inline;">
      <button class="btn danger" type="submit">Remove</button>
    </form>
  </div>
</div>

<div class="grid grid-2">
  <div class="card">
    <div class="card-head"><div class="card-title">Overview</div></div>
    <dl class="definition">
      <dt>Status</dt><dd><%= exercise.status %></dd>
      <dt>Outcome</dt><dd><%= exercise.outcome || '—' %></dd>
      <dt>Facilitator</dt><dd><%= exercise.facilitator || '—' %></dd>
      <dt>Duration</dt><dd><%= exercise.duration_minutes ? exercise.duration_minutes + ' min' : '—' %></dd>
      <dt>Participants</dt><dd><%= exercise.participants || '—' %></dd>
    </dl>
    <% if (exercise.scenario) { %>
      <div style="margin-top:10px;"><div class="card-title" style="font-size:14px;">Scenario</div><div class="md-content"><%- renderMarkdown(exercise.scenario) %></div></div>
    <% } %>
    <% if (exercise.objectives) { %>
      <div style="margin-top:10px;"><div class="card-title" style="font-size:14px;">Objectives</div><div class="md-content"><%- renderMarkdown(exercise.objectives) %></div></div>
    <% } %>
  </div>

  <div class="card">
    <div class="card-head"><div class="card-title">After-action report</div></div>
    <% if (exercise.aar_summary || exercise.aar_strengths || exercise.aar_gaps || exercise.aar_actions) { %>
      <% if (exercise.aar_summary) { %><div><div class="card-title" style="font-size:14px;">Summary</div><div class="md-content"><%- renderMarkdown(exercise.aar_summary) %></div></div><% } %>
      <% if (exercise.aar_strengths) { %><div style="margin-top:10px;"><div class="card-title" style="font-size:14px;">Strengths</div><div class="md-content"><%- renderMarkdown(exercise.aar_strengths) %></div></div><% } %>
      <% if (exercise.aar_gaps) { %><div style="margin-top:10px;"><div class="card-title" style="font-size:14px;">Gaps</div><div class="md-content"><%- renderMarkdown(exercise.aar_gaps) %></div></div><% } %>
      <% if (exercise.aar_actions) { %><div style="margin-top:10px;"><div class="card-title" style="font-size:14px;">Follow-up actions</div><div class="md-content"><%- renderMarkdown(exercise.aar_actions) %></div></div><% } %>
    <% } else { %>
      <p class="muted">No AAR captured yet. Edit this exercise to record the debrief.</p>
    <% } %>
  </div>
</div>
