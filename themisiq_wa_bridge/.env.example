# ── Bridge ───────────────────────────────────────────────
BRIDGE_BASE_URL=http://localhost:8000
LOG_LEVEL=INFO
OFFLINE_MODE=true            # true for local smoke tests; false in production

# ── WhatsApp (Meta Cloud API by default; set WA_PROVIDER=twilio to use Twilio) ──
WA_PROVIDER=meta
WA_VERIFY_TOKEN=change_me_verify_token
WA_TOKEN=your_meta_permanent_token
WA_PHONE_NUMBER_ID=your_phone_number_id
WA_API_VERSION=v19.0
# Twilio (only if WA_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── ThemisIQ ────────────────────────────────────────────
THEMIS_BASE_URL=https://themisiq.net
THEMIS_TENANT_MAP_PATH=tenant_map.json
# HMAC-SHA256 secret ThemisIQ uses to sign outbound webhooks.
# MUST match the secret configured for the webhook target in ThemisIQ's
# admin (Settings -> Webhooks). If it does not match, the bridge rejects
# the payload with HTTP 401. Leave blank only for local dev with no secret.
THEMIS_WEBHOOK_SECRET=change_me_webhook_secret

# ── LLM (reuse ThemisIQ's provider set) ─────────────────
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OLLAMA_HOST=http://localhost:11434
AI_MODEL=claude-sonnet-4

# ── Operational ──────────────────────────────────────────
MESSAGE_LOG_RETENTION_DAYS=90
AUDIT_LOG_PATH=audit.log.jsonl
RATE_LIMIT_PER_USER_PER_MIN=10
