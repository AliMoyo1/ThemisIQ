<div class="page-head">
  <div>
    <a href="/training" class="muted">&larr; All training</a>
    <h1><%= mod.title %></h1>
    <p><%= mod.description || 'No description provided.' %></p>
  </div>
  <div class="actions">
    <% if (['admin','manager'].includes(user.role)) { %>
      <a class="btn" href="/training/<%= mod.id %>/edit">Edit</a>
      <form method="POST" action="/training/<%= mod.id %>/delete" style="display:inline;" onsubmit="return confirm('Delete this module and all attestations?');">
        <button class="btn danger" type="submit">Delete</button>
      </form>
    <% } %>
  </div>
</div>

<div class="grid grid-4" style="margin-bottom:16px;">
  <div class="card kpi"><div class="kpi-label">Category</div><div class="kpi-value" style="font-size:18px;"><%= mod.category || '—' %></div></div>
  <div class="card kpi"><div class="kpi-label">Duration</div><div class="kpi-value"><%= mod.duration_minutes || '—' %><span style="font-size:14px;"> min</span></div></div>
  <div class="card kpi"><div class="kpi-label">Renewal</div><div class="kpi-value"><%= mod.renewal_months ? (mod.renewal_months + ' mo') : 'one-time' %></div></div>
  <div class="card kpi"><div class="kpi-label">Completion</div><div class="kpi-value"><%= completionPct %>%</div><div class="muted" style="font-size:12px;"><%= completion %>/<%= totalUsers %> users</div></div>
</div>

<div class="grid grid-2" style="margin-bottom:16px;">
  <div class="card">
    <div class="card-head"><div class="card-title">Module content</div></div>
    <div class="markdown-body" style="white-space:pre-wrap; font-family:Inter, sans-serif; line-height:1.55;">
<%= mod.content || '(No content yet — the author has not added any material.)' %>
    </div>
  </div>

  <div class="card">
    <div class="card-head"><div class="card-title">My attestation</div></div>
    <% if (mine && !isExpired) { %>
      <p class="muted">You signed this module on <strong><%= mine.attested_at %></strong>.</p>
      <% if (mine.expires_at) { %>
        <p class="muted">Your attestation expires on <strong><%= mine.expires_at %></strong>.</p>
      <% } %>
      <p><span class="badge success">Completed</span></p>
    <% } else { %>
      <% if (mine && isExpired) { %>
        <p class="muted"><span class="badge warn">Expired</span> Your previous attestation expired on <%= mine.expires_at %>. Please re-attest below.</p>
      <% } else { %>
        <p class="muted">Review the content on the left, then sign by typing your full name.</p>
      <% } %>
      <form method="POST" action="/training/<%= mod.id %>/attest" class="stack-10">
        <div><label>Type your full name as e-signature</label>
          <input name="signature" required placeholder="<%= user.name %>" autocomplete="off"/></div>
        <div><label>Self-assessed score (0-100)</label>
          <input type="number" name="score" min="0" max="100" value="100"/></div>
        <button class="btn primary" type="submit">I have read and understood — sign</button>
      </form>
    <% } %>
  </div>
</div>

<div class="card">
  <div class="card-head"><div class="card-title">Recent attestations <span class="count-chip"><%= attestations.length %></span></div></div>
  <% if (attestations.length === 0) { %>
    <p class="muted" style="padding:16px 0;">No one has signed off on this module yet.</p>
  <% } else { %>
    <table class="table">
      <thead><tr><th>User</th><th>Signed at</th><th>Score</th><th>Expires</th><th>IP</th></tr></thead>
      <tbody>
        <% attestations.forEach(a => { %>
          <tr>
            <td><%= a.user_name || a.user_email || '—' %><% if (a.user_email) { %><div class="muted" style="font-size:12px;"><%= a.user_email %></div><% } %></td>
            <td><%= a.attested_at %></td>
            <td><%= a.score ?? '—' %></td>
            <td><%= a.expires_at || '—' %></td>
            <td class="muted" style="font-size:12px;"><%= a.ip || '—' %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>
