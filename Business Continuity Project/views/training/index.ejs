<div class="page-head">
  <div>
    <h1>Training & Attestation</h1>
    <p>Publish BCM training modules and capture signed attestations from your team.</p>
  </div>
  <div class="actions">
    <% if (['admin','manager'].includes(user.role)) { %>
      <a class="btn" href="/training/log/all">Attestation log</a>
      <a class="btn primary" href="/training/new">+ New module</a>
    <% } %>
  </div>
</div>

<div class="grid grid-4" style="margin-bottom:16px;">
  <div class="card kpi"><div class="kpi-label">Modules</div><div class="kpi-value"><%= stats.modules %></div></div>
  <div class="card kpi"><div class="kpi-label">Active</div><div class="kpi-value"><%= stats.activeModules %></div></div>
  <div class="card kpi"><div class="kpi-label">My outstanding</div><div class="kpi-value"><%= stats.myOutstanding %></div></div>
  <div class="card kpi"><div class="kpi-label">Attestations logged</div><div class="kpi-value"><%= stats.totalAttestations %></div></div>
</div>

<div class="card">
  <% if (modules.length === 0) { %>
    <p class="muted" style="padding:20px 0;">No training modules yet. <% if (['admin','manager'].includes(user.role)) { %>Create your first module to get started.<% } %></p>
  <% } else { %>
    <table class="table">
      <thead>
        <tr>
          <th>Module</th><th>Category</th><th>Duration</th><th>Renewal</th>
          <th>Required roles</th><th>Status</th><th>My status</th><th></th>
        </tr>
      </thead>
      <tbody>
        <% modules.forEach(m => {
           const myCls = m.my_status === 'Completed' ? 'success' : (m.my_status === 'Expired' ? 'warn' : 'muted');
           const statusCls = m.status === 'active' ? 'success' : 'muted';
        %>
          <tr>
            <td><strong><%= m.title %></strong><% if (m.description) { %><div class="muted" style="font-size:12px;"><%= m.description.slice(0, 80) %><%= m.description.length > 80 ? '…' : '' %></div><% } %></td>
            <td><%= m.category || '—' %></td>
            <td><%= m.duration_minutes ? (m.duration_minutes + ' min') : '—' %></td>
            <td><%= m.renewal_months ? (m.renewal_months + ' mo') : 'one-time' %></td>
            <td><span class="muted" style="font-size:12px;"><%= m.required_roles || 'All' %></span></td>
            <td><span class="badge <%= statusCls %>"><%= m.status %></span></td>
            <td><span class="badge <%= myCls %>"><%= m.my_status %></span></td>
            <td class="right"><a href="/training/<%= m.id %>">Open</a></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>
