<div class="page-head">
  <div>
    <h1>Board report — <%= metrics.label %></h1>
    <p>Preview · <%= metrics.periodStart %> → <%= metrics.periodEnd %> · <%= metrics.tenantName %></p>
  </div>
  <div class="actions">
    <a class="btn" href="/reports">Back</a>
    <form method="POST" action="/reports/board.docx" style="display:inline;" data-ai="Composing the board narrative and assembling metrics…">
      <input type="hidden" name="start" value="<%= metrics.periodStart %>">
      <input type="hidden" name="end" value="<%= metrics.periodEnd %>">
      <input type="hidden" name="label" value="<%= metrics.label %>">
      <button class="btn primary" type="submit">Export to Word</button>
    </form>
  </div>
</div>

<div class="grid grid-4" style="margin-bottom:16px;">
  <div class="kpi">
    <div class="k-label">Program pulse</div>
    <div class="k-value"><%= metrics.pulse %>/100</div>
    <div class="k-delta"><%= metrics.pulse >= 80 ? 'Strong' : metrics.pulse >= 65 ? 'Healthy' : metrics.pulse >= 50 ? 'Caution' : 'At risk' %></div>
  </div>
  <div class="kpi">
    <div class="k-label">Risk · Ex · Compliance · Coverage</div>
    <div class="k-value" style="font-size:20px;"><%= metrics.riskHealth %> · <%= metrics.exerciseHealth %> · <%= metrics.complianceHealth %> · <%= metrics.coverageHealth %></div>
    <div class="k-delta">Dimension scores (0-100)</div>
  </div>
  <div class="kpi">
    <div class="k-label">Process coverage</div>
    <div class="k-value"><%= (metrics.coverage && metrics.coverage.pct) || 0 %>%</div>
    <div class="k-delta"><%= (metrics.coverage && metrics.coverage.green) || 0 %>/<%= (metrics.coverage && metrics.coverage.total) || 0 %> with primary plan · <%= (metrics.coverage && metrics.coverage.orphanPlansCount) || 0 %> orphan plan(s)</div>
  </div>
  <div class="kpi">
    <div class="k-label">In period</div>
    <div class="k-value"><%= metrics.counts.incidentCount %> · <%= metrics.counts.exerciseCount %></div>
    <div class="k-delta">Incidents · Exercises</div>
  </div>
</div>

<div class="card" style="margin-bottom:16px;">
  <div class="card-head"><div class="card-title">Top 10 risks</div></div>
  <% if (!metrics.topRisks.length) { %><p class="muted">No risks tracked yet.</p>
  <% } else { %>
    <table class="md-table" style="width:100%; border-collapse:collapse;">
      <thead><tr>
        <th style="text-align:left;">Title</th><th>Category</th><th>Owner</th>
        <th>L</th><th>I</th><th>Score</th><th>Status</th>
      </tr></thead>
      <tbody>
        <% metrics.topRisks.forEach(r => { %>
          <tr>
            <td><%= r.title %></td>
            <td><%= r.category || '—' %></td>
            <td><%= r.owner || '—' %></td>
            <td><%= r.likelihood ?? '—' %></td>
            <td><%= r.impact ?? '—' %></td>
            <td><%= r.score ?? (r.likelihood && r.impact ? r.likelihood * r.impact : '—') %></td>
            <td><%= r.status || 'open' %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>

<div class="grid grid-2" style="margin-bottom:16px;">
  <div class="card">
    <div class="card-head"><div class="card-title">Incidents by severity</div></div>
    <table class="md-table" style="width:100%; border-collapse:collapse;">
      <thead><tr><th style="text-align:left;">Severity</th><th>Count</th></tr></thead>
      <tbody>
        <% Object.keys(metrics.incidentsBySev).forEach(k => { %>
          <tr><td><span class="badge severity-<%= k %>"><%= k %></span></td><td><%= metrics.incidentsBySev[k] %></td></tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <div class="card">
    <div class="card-head"><div class="card-title">Compliance maturity</div></div>
    <% if (!metrics.complianceRows.length) { %><p class="muted">No frameworks tracked.</p>
    <% } else { %>
      <table class="md-table" style="width:100%; border-collapse:collapse;">
        <thead><tr><th style="text-align:left;">Framework</th><th>Controls</th><th>Implemented</th><th>Maturity</th></tr></thead>
        <tbody>
          <% metrics.complianceRows.forEach(c => { %>
            <tr>
              <td><%= c.framework %></td>
              <td><%= c.total %></td>
              <td><%= c.implemented %></td>
              <td><strong><%= c.maturity_pct %>%</strong></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>
</div>

<div class="card" style="margin-bottom:16px;">
  <div class="card-head"><div class="card-title">Exercise outcomes</div></div>
  <% if (!metrics.exercises.length) { %><p class="muted">No exercises in this window.</p>
  <% } else { %>
    <table class="md-table" style="width:100%; border-collapse:collapse;">
      <thead><tr><th style="text-align:left;">Date</th><th>Type</th><th>Title</th><th>Facilitator</th><th>Outcome</th><th>Status</th></tr></thead>
      <tbody>
        <% metrics.exercises.forEach(e => { %>
          <tr>
            <td><%= e.scheduled_date || '—' %></td>
            <td><%= e.type || '—' %></td>
            <td><%= e.title %></td>
            <td><%= e.facilitator || '—' %></td>
            <td><%= e.outcome || '—' %></td>
            <td><%= e.status || '—' %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>

<div class="card" style="margin-bottom:16px;">
  <div class="card-head"><div class="card-title">Coverage of critical processes</div></div>
  <% const cov = metrics.coverage || { total:0, green:0, amber:0, red:0, pct:0, criticalExposed:[], orphanPlansCount:0 }; %>
  <div class="grid grid-4" style="margin-bottom:12px;">
    <div class="kpi"><div class="k-label">Covered</div><div class="k-value"><span class="badge success" style="font-size:13px; padding:5px 10px;"><%= cov.green %></span></div></div>
    <div class="kpi"><div class="k-label">Partial</div><div class="k-value"><span class="badge warn" style="font-size:13px; padding:5px 10px;"><%= cov.amber %></span></div></div>
    <div class="kpi"><div class="k-label">No plan</div><div class="k-value"><span class="badge danger" style="font-size:13px; padding:5px 10px;"><%= cov.red %></span></div></div>
    <div class="kpi"><div class="k-label">Orphan plans</div><div class="k-value"><span class="badge muted" style="font-size:13px; padding:5px 10px;"><%= cov.orphanPlansCount %></span></div></div>
  </div>
  <% if (!cov.criticalExposed.length) { %>
    <p class="muted">Every Critical and High process has a primary plan.</p>
  <% } else { %>
    <p class="muted" style="font-size:13px; margin-top:0;">Critical / High processes without a primary plan — decisions the board should weigh in on.</p>
    <table class="md-table" style="width:100%; border-collapse:collapse;">
      <thead><tr><th style="text-align:left;">Process</th><th>Department</th><th>Criticality</th><th>RTO</th><th>Owner</th><th>State</th></tr></thead>
      <tbody>
        <% cov.criticalExposed.slice(0, 10).forEach(r => { %>
          <tr>
            <td><%= r.process_name %></td>
            <td><%= r.department || '—' %></td>
            <td><%= r.criticality %></td>
            <td><%= r.rto_hours != null ? r.rto_hours + ' hrs' : '—' %></td>
            <td><%= r.owner || '—' %></td>
            <td><span class="badge <%= r.state === 'amber' ? 'warn' : 'danger' %>"><%= r.state === 'amber' ? 'Partial' : 'No plan' %></span></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>

<div class="card">
  <div class="card-head"><div class="card-title">Top 5 critical vendors</div></div>
  <% if (!metrics.topVendors.length) { %><p class="muted">No vendors tracked yet.</p>
  <% } else { %>
    <table class="md-table" style="width:100%; border-collapse:collapse;">
      <thead><tr><th style="text-align:left;">Vendor</th><th>Category</th><th>Criticality</th><th>Tier</th><th>Risk</th><th>Renewal</th></tr></thead>
      <tbody>
        <% metrics.topVendors.forEach(v => { %>
          <tr>
            <td><%= v.name %></td>
            <td><%= v.category || '—' %></td>
            <td><%= v.criticality || '—' %></td>
            <td><%= v.tier || '—' %></td>
            <td><%= v.risk_score ?? '—' %></td>
            <td><%= v.contract_renewal || '—' %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>
