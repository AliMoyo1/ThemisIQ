<div class="page-head">
  <div>
    <h1>AI Plan Generator</h1>
    <p>Describe the scenario and scope, and the copilot will draft a full BCP for you.</p>
  </div>
  <div class="actions"><a class="btn" href="/bcp">Back to plans</a></div>
</div>

<div class="grid grid-2">
  <div class="card">
    <div class="card-head"><div class="card-title">Inputs</div></div>
    <form method="POST" action="/plan-generator" class="stack-16" data-ai="Drafting your continuity plan…">
      <div><label>Scope / system / business unit</label><input name="scope" required value="<%= form.scope || '' %>" placeholder="e.g. E-commerce checkout, London office, Finance team" /></div>
      <div><label>Scenario / disruption</label><textarea name="scenario" placeholder="e.g. Extended cloud outage affecting all production workloads for 12+ hours"><%= form.scenario || '' %></textarea></div>
      <div><label>Industry context (optional)</label><input name="industry" value="<%= form.industry || '' %>" /></div>
      <button class="btn primary" type="submit">Generate draft</button>
    </form>
  </div>

  <div class="card">
    <div class="card-head"><div class="card-title">Draft</div></div>
    <% if (!draft) { %>
      <p class="muted">Submit the form to generate a Markdown plan draft. You can then review and save it to your BCP library in one click.</p>
    <% } else { %>
      <p class="muted">Generated via <%= draft.provider %>. Review, edit, then save.</p>
      <form method="POST" action="/plan-generator/save" class="stack-10">
        <input type="text" name="title" value="<%= draft.title %>" required />
        <input type="hidden" name="scope" value="<%= form.scope %>" />
        <textarea name="content" style="min-height:380px; font-family: ui-monospace, SFMono-Regular, Menlo, monospace;"><%= draft.content %></textarea>
        <div class="flex gap-8">
          <button class="btn primary" type="submit">Save to BCP library</button>
          <a class="btn" href="/plan-generator">Discard</a>
        </div>
      </form>
    <% } %>
  </div>
</div>
