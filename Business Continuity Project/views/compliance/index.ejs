<div class="page-head">
  <div>
    <h1>Compliance · <%= framework %></h1>
    <p>Track control implementation against the selected framework.</p>
  </div>
  <div class="actions">
    <form method="GET" action="/compliance" style="display:inline;">
      <select name="framework" onchange="this.form.submit()">
        <% frameworks.forEach(f => { %>
          <option value="<%= f %>" <%= f === framework ? 'selected' : '' %>><%= f %></option>
        <% }) %>
      </select>
    </form>
  </div>
</div>

<div class="grid grid-4" style="margin-bottom:16px;">
  <div class="card kpi"><div class="kpi-label">Controls</div><div class="kpi-value"><%= rows.length %></div></div>
  <div class="card kpi"><div class="kpi-label">Implemented</div><div class="kpi-value"><%= counts.implemented %></div></div>
  <div class="card kpi"><div class="kpi-label">Verified</div><div class="kpi-value"><%= counts.verified %></div></div>
  <div class="card kpi"><div class="kpi-label">Maturity</div><div class="kpi-value"><%= maturity %>%</div></div>
</div>

<div class="card">
  <table class="table">
    <thead><tr><th>Clause</th><th>Title</th><th>Owner</th><th>Status</th><th>Next review</th><th></th></tr></thead>
    <tbody>
      <% rows.forEach(c => {
         const statusCls = c.status === 'verified' ? 'success' : (c.status === 'implemented' ? 'info' : (c.status === 'in_progress' ? 'warn' : 'muted'));
      %>
        <tr>
          <td><strong><%= c.clause %></strong></td>
          <td><%= c.title %></td>
          <td><%= c.owner || '—' %></td>
          <td><span class="badge <%= statusCls %>"><%= c.status.replace('_',' ') %></span></td>
          <td><%= c.next_review || '—' %></td>
          <td class="right"><a href="/compliance/<%= c.id %>">Open</a></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
